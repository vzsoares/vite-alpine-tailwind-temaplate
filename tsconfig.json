{
    "compilerOptions": {
        "target": "es2017",
        "module": "commonjs",
        "jsx": "react-jsx",
        "jsxImportSource": "@kitajs/html",
        "plugins": [{ "name": "@kitajs/ts-html-plugin" }],
        "declaration": true,
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "lib": ["es2017", "dom", "esnext.disposable"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "**/*.test.ts"]
}
