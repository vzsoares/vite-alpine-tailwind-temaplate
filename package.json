{
    "name": "vite-alpine-tailwind-temaplate",
    "version": "2.3.0",
    "description": "A lightweight starter template combining Vite, Alpine.js and Tailwind CSS for building modern, interactive web applications",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "xss-scan": "xss-scan --project tsconfig.scan.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "release": "release-it"
    },
    "release-it": {
        "git": {
            "push": true
        },
        "github": {
            "release": true,
            "releaseName": "Release ${version}"
        },
        "npm": {
            "publish": false
        }
    },
    "keywords": [
        "vite",
        "alpinejs",
        "tailwindcss",
        "template",
        "starter",
        "frontend",
        "spa",
        "web-development",
        "typescript"
    ],
    "author": "vzsoares",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/vzsoares/vite-alpine-tailwind-temaplate.git"
    },
    "homepage": "https://github.com/vzsoares/vite-alpine-tailwind-temaplate",
    "bugs": {
        "url": "https://github.com/vzsoares/vite-alpine-tailwind-temaplate/issues"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@kitajs/html": "^5.0.0-next.1",
        "@kitajs/ts-html-plugin": "^5.0.0-next.1",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/vite": "^4.3.0",
        "@types/alpinejs": "^3.13.11",
        "alpinejs": "^3.15.12",
        "release-it": "^20.0.1",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "dependencies": {}
}
