{
    "name": "vite-alpine-tailwind-x",
    "version": "2.10.0",
    "description": "A batteries-included Vite + Alpine.js + Tailwind CSS static-site template: type-safe JSX prerendering, Markdown blog, full-text search, SEO and social cards",
    "scripts": {
        "dev": "vite",
        "build": "vite build && pagefind --site dist",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "xss-scan": "xss-scan --project tsconfig.scan.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:preview": "playwright test --config playwright.preview.config.ts",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write ."
    },
    "keywords": [
        "vite",
        "alpinejs",
        "tailwindcss",
        "template",
        "starter",
        "frontend",
        "spa",
        "web-development",
        "typescript"
    ],
    "author": "vzsoares",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/vzsoares/vite-alpine-tailwind-x.git"
    },
    "homepage": "https://github.com/vzsoares/vite-alpine-tailwind-x",
    "bugs": {
        "url": "https://github.com/vzsoares/vite-alpine-tailwind-x/issues"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@kitajs/html": "^5.0.0-next.1",
        "@kitajs/ts-html-plugin": "^5.0.0-next.1",
        "@playwright/test": "^1.60.0",
        "@resvg/resvg-js": "^2.6.2",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.0",
        "@types/alpinejs": "^3.13.11",
        "alpinejs": "^3.15.12",
        "daisyui": "^5.5.20",
        "htmx.org": "^2.0.10",
        "marked": "^18.0.4",
        "pagefind": "^1.5.2",
        "shiki": "^4.1.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "dependencies": {}
}
